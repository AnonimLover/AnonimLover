<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Sadece Senin İçin</title>
    <style>
        body {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
            font-family: 'Segoe UI', sans-serif;
            color: #fff;
            text-align: center;
            padding: 20px;
        }
        #mesaj {
            font-size: 1.8rem;
            margin-bottom: 20px;
            padding: 20px;
            max-width: 80%;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.2);
        }
        #imza {
            font-size: 1rem;
            opacity: 0.8;
            margin-bottom: 20px;
            font-weight: bold;
        }
        #btn {
            padding: 15px 40px;
            font-size: 1.2rem;
            cursor: pointer;
            border: none;
            border-radius: 50px;
            background: #fff;
            color: #ff9a9e;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: 0.3s;
        }
        #btn:hover { transform: scale(1.05); background: #fdfcf0; }
    </style>
</head>
<body>

    <div id="mesaj">Sana özel bir şey hazırladım, tıklar mısın?</div>
    <div id="imza"></div>
    <button id="btn">Tıkla</button>

    <script>
        const sonMesaj = "Bazen bazı şeyleri söylemek zor olur... Ama bazı insanların ne kadar değerli olduğunu söylemek gerekir. Bu sayfayı seni gerçekten önemseyen biri hazırladı. 💙";
        const iltifatlar = [
            "Dünyanın en güzel gülüşüne sahipsin.",
            "Gülüşün istemsizce beni de gülümsetiyor.",
            "Seninle konuşmak günümün güzel geçen anlarından biri oluyor.",
            "Enerjin bulunduğun ortamı güzelleştiriyor.",
            "Seni tanıdığıma gerçekten mutluyum.",
            "Bazen neşen bana da iyi geliyor.",
            "Zekan ve düşünce şeklin dikkatimi çekiyor.",
            "Seninle sohbet etmek hiç sıkıcı olmuyor.",
            "Küçük şeylerden mutlu olabilmen hoşuma gidiyor.",
            "Kendin olabilen insanlardan biri olman güzel.",
            "Belki farkında değilsin ama birçok insanın gününü güzelleştiriyorsun."
        ];

        // Diziyi karıştır
        for (let i = iltifatlar.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [iltifatlar[i], iltifatlar[j]] = [iltifatlar[j], iltifatlar[i]];
        }

        let tiklamaSayisi = 0;
        const btn = document.getElementById('btn');
        const mesaj = document.getElementById('mesaj');
        const imza = document.getElementById('imza');

        btn.addEventListener('click', () => {
            tiklamaSayisi++;
            
            if (tiklamaSayisi <= iltifatlar.length) {
                mesaj.innerText = iltifatlar[tiklamaSayisi - 1];
            } 
            
            if (tiklamaSayisi > iltifatlar.length) {
                mesaj.innerText = sonMesaj;
                imza.innerText = "Made by Anonim";
                btn.style.display = "none";
            }
        });
    </script>
</body>
</html>
